{
  "manifest_version": 3,
  "name": "GitHub StarLists++",
  "description": "GitHub StarLists++",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/shared/base.js",
        "src/shared/storage.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GitHub StarLists++ settings",
    "default_popup": "src/options.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "githubstarlistsplus@fldicoahkiin.local",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
